# Startup Apps
# Runs when the sway is started, terminate when stopped
# Similar to .xinitrc

# Update turnstile shared env
exec_always turnstile-update-runit-env \
  WAYLAND_DISPLAY \
  DISPLAY \
  XDG_CURRENT_DESKTOP=sway

# Services tied to compositor
exec batsignal
exec wlsunset -l 40.325939 -L -78.917488
exec foot --server
exec footclient cmus
exec swayidle -w \
	timeout 300 'swaylock-blur -f -c 000000' \
	timeout 600 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
	before-sleep 'swaylock-blur -f -c 000000'

